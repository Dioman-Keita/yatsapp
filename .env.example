# Better Auth Configuration
BETTER_AUTH_SECRET=your_secret_key_here
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUST_ORIGIN=https://yatsapp.vercel.app/,http://localhost:3000

# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require&channel_binding=require

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Resend Email API
RESEND_API_KEY=your_resend_api_key_here

# Pusher Configuration (Real-time messaging)
PUSHER_APP_ID=your_pusher_app_id_here
PUSHER_KEY=your_pusher_key_here
PUSHER_SECRET=your_pusher_secret_here
PUSHER_CLUSTER=eu

# Pusher Public Keys
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key_here
NEXT_PUBLIC_PUSHER_CLUSTER=eu
